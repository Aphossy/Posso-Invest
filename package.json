{
  "name": "trustlink-group-website",
  "description": "TrustLink Group - Connecting Opportunities, Empowering Growth in Rwanda and Beyond.",
  "author": "TrustLink Group",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "keywords": [
    "rwanda",
    "nextjs",
    "typescript",
    "drizzle",
    "postgresql",
    "trustlink-group"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "postbuild": "next-sitemap",
    "preview": "next build && next start",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,md,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,mdx}\" --cache",
    "format:ultracite": "npx ultracite format",
    "check:meta": "npx check-site-meta 3000",
    "check:favicon": "npx realfavicon check 3000",
    "unused:deps": "npx depcheck --skip-missing",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next out",
    "build:full": "bun run typecheck && bun run lint && next build",
    "prod:test": "bun run build && bun run start",
    "audit": "bun audit",
    "security": "bun audit fix",
    "update:deps": "bun update --save",
    "validate": "bun run lint && bun run typecheck && bun run format:check",
    "analyze:bundle": "ANALYZE=true next build",
    "shadcn:all": "npx shadcn@latest add --all",
    "shadcn:monorepo": "npx shadcn@latest migrate radix",
    "db:generate": "npx drizzle-kit generate",
    "db:generate:staging": "NODE_ENV=staging drizzle-kit generate",
    "db:generate:prod": "NODE_ENV=production drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "db:setup": "bun run db:generate && bun run db:migrate && bun run db:seed",
    "db:check": "npx drizzle-kit check",
    "knip": "knip",
    "prepare": "husky",
    "test-payment": "tsx scripts/test/auction-winner-notification.ts",
    "debug:auction-data": "tsx scripts/debug-auction-data.ts",
    "env:validate": "tsx scripts/validate-env.ts",
    "env:validate:staging": "NODE_ENV=staging tsx scripts/validate-env.ts",
    "env:validate:prod": "NODE_ENV=production tsx scripts/validate-env.ts",
    "commitlint": "commitlint --edit",
    "commitlint:last": "commitlint --last --verbose",
    "email": "email dev --dir emails --port 3000",
    "inngest:dev": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:3000/api/inngest"
  },
